{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Security Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "host",
    "source",
    "category",
    "rule_id",
    "title",
    "severity",
    "status",
    "evidence",
    "remediation"
  ],
  "properties": {
    "host": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "warn", "info"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remediation": {
      "type": "string"
    },
    "finding_type": {
      "type": "string",
      "enum": [
        "software_vulnerability",
        "configuration_noncompliance",
        "service_misconfiguration",
        "file_permission_issue",
        "insecure_package"
      ]
    },
    "vulnerability_id": {
      "type": ["string", "null"]
    },
    "external_ids": {
      "type": "object",
      "properties": {
        "cve": {
          "type": ["string", "null"]
        },
        "cwe": {
          "type": ["string", "null"]
        },
        "bdu": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "cvss": {
      "type": "object",
      "properties": {
        "base_score": {
          "type": ["number", "null"]
        },
        "vector": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "affected_component": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"]
        },
        "version": {
          "type": ["string", "null"]
        },
        "package": {
          "type": ["string", "null"]
        },
        "service": {
          "type": ["string", "null"]
        },
        "port": {
          "type": ["integer", "null"]
        },
        "protocol": {
          "type": ["string", "null"]
        },
        "architecture": {
          "type": ["string", "null"]
        },
        "description": {
          "type": ["string", "null"]
        },
        "size": {
          "type": ["integer", "number", "null"]
        },
        "type": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "vulnerability_class": {
      "type": ["string", "null"]
    },
    "weakness_id": {
      "type": ["string", "null"]
    },
    "weakness_type": {
      "type": ["string", "null"]
    },
    "location": {
      "type": ["string", "null"]
    },
    "impact": {
      "type": ["string", "null"]
    },
    "detected_at": {
      "type": ["string", "null"]
    },
    "description": {
      "type": ["string", "null"]
    },
    "os_platform": {
      "type": ["string", "null"]
    },
    "detection_method": {
      "type": ["string", "null"]
    },
    "cve": {
      "type": ["string", "null"]
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sca_check_id": {
      "type": ["integer", "string", "null"]
    },
    "wazuh_sca": {
      "type": "object",
      "properties": {
        "id": {
          "type": ["integer", "string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "target": {
          "type": ["string", "null"]
        },
        "result": {
          "type": ["string", "null"]
        },
        "rationale": {
          "type": ["string", "null"]
        },
        "remediation": {
          "type": ["string", "null"]
        },
        "description": {
          "type": ["string", "null"]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compliance": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "condition": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "wazuh_vulnerability": {
      "type": "object",
      "properties": {
        "_index": {
          "type": ["string", "null"]
        },
        "_id": {
          "type": ["string", "null"]
        },
        "agent": {
          "type": "object",
          "additionalProperties": true
        },
        "host": {
          "type": "object",
          "additionalProperties": true
        },
        "package": {
          "type": "object",
          "additionalProperties": true
        },
        "vulnerability": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
